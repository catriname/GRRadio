@using GRRadio.Models
@using GRRadio.Services
@inject SolarWeatherService SolarService
@inject SettingsService Settings
@inject NavigationManager Nav

<div class="page-header">
    <div class="page-title">
        <span class="callsign">@(settings?.Callsign is { Length: > 0 } c ? c : "GRRadio")</span>
        <span class="grid-badge">@(settings?.GridSquare is { Length: > 0 } g ? g : "Set Grid")</span>
    </div>
    <button class="refresh-btn" @onclick="Refresh" disabled="@loading">
        @if (loading) { <span class="spinner">⟳</span> } else { <span>⟳</span> }
    </button>
</div>

@if (!settings!.IsConfigured)
{
    <div class="alert-card alert-warn">
        <strong>Setup required</strong> — enter your callsign and grid square in
        <a @onclick='() => Nav.NavigateTo("/settings")' class="link">Settings</a>.
    </div>
}

@if (solar is not null)
{
    <!-- Solar Conditions Bar -->
    <div class="solar-bar condition-@solar.OverallCondition.ToString().ToLower()">
        <div class="solar-metric">
            <span class="metric-label">SFI</span>
            <span class="metric-value">@solar.SolarFluxIndex.ToString("F0")</span>
        </div>
        <div class="solar-metric">
            <span class="metric-label">Kp</span>
            <span class="metric-value">@solar.KIndex.ToString("F1")</span>
        </div>
        <div class="solar-metric">
            <span class="metric-label">Wind</span>
            <span class="metric-value">@solar.SolarWindSpeed.ToString("F0") km/s</span>
        </div>
        <div class="solar-metric">
            <span class="metric-label">Bz</span>
            <span class="metric-value @(solar.BzComponent < -5 ? "bz-south" : "bz-north")">@solar.BzComponent.ToString("F1")</span>
        </div>
        <div class="solar-status">
            <span class="condition-badge condition-@solar.OverallCondition.ToString().ToLower()">
                @solar.OverallCondition
            </span>
        </div>
    </div>
}

<!-- Active Alerts Strip -->
@if (alerts.Count > 0)
{
    <div class="alerts-strip">
        @foreach (var alert in alerts.Take(3))
        {
            <div class="alert-pill severity-@alert.Severity.ToString().ToLower()">
                ⚠ @alert.ShortMessage
            </div>
        }
        @if (alerts.Count > 3)
        {
            <a @onclick='() => Nav.NavigateTo("/alerts")' class="alert-pill alert-more">
                +@(alerts.Count - 3) more →
            </a>
        }
    </div>
}

<!-- Band Conditions -->
<div class="section-header">
    <h2>Band Conditions</h2>
    <span class="section-sub">@DateTime.Now.ToString("HH:mm") local</span>
</div>

@if (bands.Count > 0)
{
    <div class="band-grid">
        @foreach (var band in bands)
        {
            <div class="band-card @band.Rating.ToCssClass()">
                <div class="band-name">@band.Band</div>
                <div class="band-rating-icon">@band.Rating.ToIcon()</div>
                <div class="band-rating-label">@band.Rating.ToLabel()</div>
                <div class="band-summary">@band.Summary</div>
                @if (band.GoodRegions.Count > 0)
                {
                    <div class="band-regions">@string.Join(" · ", band.GoodRegions)</div>
                }
                @if (!string.IsNullOrEmpty(band.BestMode))
                {
                    <div class="band-mode">@band.BestMode</div>
                }
            </div>
        }
    </div>
}
else if (loading)
{
    <div class="loading-grid">
        @for (int i = 0; i < 9; i++) { <div class="band-card skeleton"></div> }
    </div>
}

<!-- 3-Day Forecast Timeline -->
@if (forecastByDay.Count > 0)
{
    <div class="section-header">
        <h2>3-Day Forecast</h2>
        <span class="section-sub">Best band per 3-hr window</span>
    </div>

    @foreach (var (day, slots) in forecastByDay)
    {
        <div class="forecast-day">
            <div class="forecast-day-label">@day</div>
            <div class="forecast-slots">
                @foreach (var slot in slots)
                {
                    var best = slot.Conditions.MaxBy(c => (int)c.Rating);
                    <div class="forecast-slot @(best?.Rating.ToCssClass() ?? "rating-closed")
                                             @(slot.Hour < DateTime.UtcNow ? "past" : "")">
                        <div class="slot-time">@slot.Hour.ToLocalTime().ToString("HH")</div>
                        <div class="slot-band">@(best?.Band ?? "—")</div>
                        <div class="slot-icon">@(best?.Rating.ToIcon() ?? "✕")</div>
                    </div>
                }
            </div>
        </div>
    }
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert-card alert-error">@errorMessage</div>
}

@code {
    private UserSettings? settings;
    private SolarData? solar;
    private List<BandCondition> bands = [];
    private List<SpaceWeatherAlert> alerts = [];
    private Dictionary<string, List<BandForecast>> forecastByDay = [];
    private bool loading = true;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        settings = Settings.Load();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        loading = true;
        errorMessage = "";
        StateHasChanged();

        try
        {
            var solarTask  = SolarService.GetCurrentAsync();
            var alertsTask = SolarService.GetAlertsAsync();
            var fcastTask  = SolarService.GetForecastAsync();

            await Task.WhenAll(solarTask, alertsTask, fcastTask);

            solar  = solarTask.Result;
            alerts = alertsTask.Result;

            if (settings is { IsConfigured: true })
            {
                var (lat, lon) = SettingsService.MaidenheadToLatLon(settings.GridSquare);
                bands = PropagationEngine.Evaluate(solar, DateTime.UtcNow, lat, lon);

                var rawForecast = PropagationEngine.BuildForecast(fcastTask.Result, lat, lon);
                forecastByDay = rawForecast
                    .GroupBy(f => f.Hour.ToLocalTime().ToString("ddd, MMM d"))
                    .ToDictionary(g => g.Key, g => g.ToList());
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to fetch solar data: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private async Task Refresh() => await LoadDataAsync();
}
