@page "/"
@using GRRadio.Models
@using GRRadio.Services
@implements IDisposable
@inject SettingsService SettingsSvc
@inject SolarWeatherService SolarService
@inject HfConditionsService HfService
@inject SatelliteService SatService
@inject PskReporterService PskSvc
@inject TravelDestinationService TravelSvc
@inject PhraseService PhraseSvc
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="page-header">
    <div class="page-title">
        <img src="grr_logo.png" class="brand-logo-small" alt="GRRadio" />
        <span class="callsign">@(settings?.Callsign is { Length: > 0 } c ? c : "GRRadio")</span>
        <span class="grid-badge">@(settings?.GridSquare is { Length: > 0 } g ? g : "Set Grid")</span>
    </div>
    <button class="refresh-btn" @onclick="LoadDataAsync" disabled="@loading">
        @if (loading) { <span class="spinner">⟳</span> } else { <span>⟳</span> }
    </button>
</div>

@if (!settings!.IsConfigured)
{
    <div class="alert-card alert-warn">
        <strong>Setup required</strong> — enter your callsign and grid square in
        <a @onclick='() => Nav.NavigateTo("/settings")' class="link">Settings</a>.
    </div>
}

<!-- ── Enhanced Greeting Card ────────────────────────────────── -->
<div class="daily-header">
    <div class="daily-time-icon">
        @if (timeOfDay == "morning")
        {
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17a5 5 0 0 1 10 0"/>
                <line x1="12" y1="9" x2="12" y2="7"/>
                <line x1="5.5" y1="10.5" x2="7" y2="12"/>
                <line x1="18.5" y1="10.5" x2="17" y2="12"/>
                <line x1="2" y1="17" x2="22" y2="17"/>
                <line x1="12" y1="5" x2="12" y2="3"/>
                <line x1="6" y1="6" x2="7.5" y2="7.5"/>
                <line x1="18" y1="6" x2="16.5" y2="7.5"/>
            </svg>
        }
        else if (timeOfDay == "afternoon")
        {
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/>
                <line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/>
                <line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
        }
        else if (timeOfDay == "evening")
        {
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17a5 5 0 0 1 10 0"/>
                <line x1="12" y1="11" x2="12" y2="9"/>
                <line x1="5.5" y1="12.5" x2="7" y2="14"/>
                <line x1="18.5" y1="12.5" x2="17" y2="14"/>
                <line x1="2" y1="17" x2="22" y2="17"/>
                <line x1="2" y1="20" x2="22" y2="20"/>
            </svg>
        }
        else
        {
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
        }
    </div>

    <div class="daily-header-text">
        <div class="daily-greeting-line">
            @greetingWord, @(settings?.Callsign is { Length: > 0 } cs ? cs : "operator").
        </div>
        <div class="daily-date-line">@DateTime.Now.ToString("dddd, MMMM d")</div>

        @if (insights.Count > 0)
        {
            var insight = insights[insightIndex];
            <div class="daily-insight-text">
                @if (!string.IsNullOrEmpty(insight.Icon))
                {
                    <span class="daily-insight-icon">@insight.Icon</span>
                }
                @insight.Text
            </div>
            @if (!string.IsNullOrEmpty(insight.SubText))
            {
                <div class="daily-insight-sub">@insight.SubText</div>
            }
            @if (insights.Count > 1)
            {
                <div class="daily-insight-dots">
                    @for (int i = 0; i < insights.Count; i++)
                    {
                        var idx = i;
                        <span class="insight-dot @(idx == insightIndex ? "insight-dot-active" : "")"
                              @onclick="() => { insightIndex = idx; }"></span>
                    }
                </div>
            }
        }
    </div>
</div>

<!-- ── Destinations (collapsible) ───────────────────────────── -->
@if (destinations.Count > 0 || destLoading)
{
    <div class="collapsible-header" @onclick="() => showDestinations = !showDestinations">
        <h2>Destinations</h2>
        <span class="collapse-chevron">@(showDestinations ? "▲" : "▼")</span>
    </div>

    @if (showDestinations)
    {
        @if (destLoading)
        {
            <div class="dest-card dest-skeleton">
                <div class="dest-skeleton-img"></div>
                <div class="dest-skeleton-text"></div>
            </div>
        }
        else
        {
            @foreach (var dest in destinations)
            {
                var isFlipped = flippedCards.Contains(dest.Name);
                <div class="dest-card @(isFlipped ? "flipped" : "")"
                     @onclick="() => ToggleDestFlip(dest.Name)">
                    <div class="dest-flip-inner">

                        <!-- FRONT: image + name + location -->
                        <div class="dest-front">
                            @if (!string.IsNullOrEmpty(dest.ImageUrl))
                            {
                                <img class="dest-image" src="@dest.ImageUrl" alt="@dest.Name"
                                     onerror="this.style.display='none'" />
                            }
                            <div class="dest-front-body">
                                <div class="dest-title-row">
                                    <span class="dest-name">@dest.Name</span>
                                    @if (!string.IsNullOrEmpty(dest.PotaReference))
                                    {
                                        <span class="dest-pota-ref">@dest.PotaReference</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(dest.LocationName))
                                {
                                    <div class="dest-location">@dest.LocationName</div>
                                }
                                <div class="dest-flip-hint">tap to flip ↻</div>
                            </div>
                        </div>

                        <!-- BACK: description + grid + distance -->
                        <div class="dest-back">
                            <div class="dest-back-body">
                                <div class="dest-back-name">@dest.Name</div>
                                @if (!string.IsNullOrEmpty(dest.Description))
                                {
                                    <div class="dest-description">@dest.Description</div>
                                }
                                <div class="dest-stats">
                                    @if (!string.IsNullOrEmpty(dest.Grid))
                                    {
                                        <span class="dest-stat">
                                            <span class="dest-stat-label">Grid</span>@dest.Grid
                                        </span>
                                    }
                                    @if (dest.DistanceKm > 0)
                                    {
                                        <span class="dest-stat">
                                            <span class="dest-stat-label">Distance</span>@dest.DistanceDisplay
                                        </span>
                                    }
                                    @if (dest.ActivatorCount > 0)
                                    {
                                        <span class="dest-stat">
                                            <span class="dest-stat-label">Activations</span>@dest.ActivatorCount
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        }
    }
}

<!-- ── Band Conditions (collapsible) ────────────────────────── -->
<div class="collapsible-header" @onclick="() => showBands = !showBands">
    <h2>Band Conditions</h2>
    <span class="collapse-chevron">@(showBands ? "▲" : "▼")</span>
</div>

@if (showBands)
{
    @if (bands.Count > 0)
    {
        <div class="band-grid">
            @foreach (var band in bands)
            {
                <div class="band-card @band.Rating.ToCssClass()">
                    <div class="band-name">@band.Band</div>
                    <div class="band-rating-icon">@band.Rating.ToIcon()</div>
                    <div class="band-rating-label">@band.Rating.ToLabel()</div>
                    <div class="band-summary">@band.Summary</div>
                    @if (band.GoodRegions.Count > 0)
                    {
                        <div class="band-regions">@string.Join(" · ", band.GoodRegions)</div>
                    }
                    @if (!string.IsNullOrEmpty(band.BestMode))
                    {
                        <div class="band-mode">@band.BestMode</div>
                    }
                </div>
            }
        </div>
    }
    else if (loading)
    {
        <div class="loading-grid">
            @for (int i = 0; i < 9; i++) { <div class="band-card skeleton"></div> }
        </div>
    }
}

<!-- ── Upcoming Passes (collapsible) ────────────────────────── -->
@if (settings!.SatellitesEnabled && settings.IsConfigured && passes.Count > 0)
{
    var visiblePasses = passes.Where(p => p.IsActive || p.IsUpcoming)
                             .OrderBy(p => p.IsActive ? DateTime.MinValue : p.AosTime).ToList();

    <div class="collapsible-header" @onclick="() => showPasses = !showPasses">
        <h2>Upcoming Passes</h2>
        <span class="collapse-chevron">@(showPasses ? "▲" : "▼")</span>
    </div>

    @if (showPasses)
    {
        <div class="report-pass-list">
            @foreach (var p in visiblePasses.Take(passLimit))
            {
                <div class="report-pass-item @(p.IsActive ? "pass-active" : "")">
                    <div class="report-pass-sat">
                        @p.SatelliteName
                        @if (p.IsActive)
                        {
                            <span class="active-badge">● LIVE</span>
                        }
                    </div>
                    <div class="report-pass-desc">@p.AosTimeLocal → @p.LosTimeLocal · @p.AosDirection to @p.LosDirection</div>
                    <div class="report-pass-badge @p.PassQualityCss">@p.PassQuality · @p.MaxElevationStr</div>
                </div>
            }
        </div>
        @if (visiblePasses.Count > passLimit)
        {
            <button class="btn-ghost show-more-btn" @onclick="() => passLimit += 5">
                Show more (@(visiblePasses.Count - passLimit) remaining)
            </button>
        }
    }
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert-card alert-error">@errorMessage</div>
}

@code {
    private UserSettings? settings;
    private SolarData?    solar;
    private List<BandCondition>    bands  = [];
    private List<SpaceWeatherAlert> alerts = [];
    private List<SatellitePass>    passes = [];
    private List<DestinationInfo>  destinations = [];
    private int passLimit = 5;
    private bool loading     = true;
    private bool destLoading = false;
    private string errorMessage = "";

    private bool showBands        = true;
    private bool showPasses       = true;
    private bool showDestinations = true;

    private HashSet<string> flippedCards = [];
    private void ToggleDestFlip(string name)
    {
        if (!flippedCards.Remove(name))
            flippedCards.Add(name);
    }

    // ── Greeting insights rotation ────────────────────────────────
    private List<GreetingInsight> insights  = [];
    private int insightIndex = 0;
    private System.Timers.Timer? _insightTimer;

    private string timeOfDay => DateTime.Now.Hour switch
    {
        >= 5 and < 12  => "morning",
        >= 12 and < 17 => "afternoon",
        >= 17 and < 21 => "evening",
        _              => "night"
    };

    private string greetingWord => timeOfDay switch
    {
        "morning"   => "Good morning",
        "afternoon" => "Good afternoon",
        "evening"   => "Good evening",
        _           => "Good night"
    };

    protected override async Task OnInitializedAsync()
    {
        settings = SettingsSvc.Load();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        loading      = true;
        errorMessage = "";
        passLimit    = 5;
        destinations = [];
        destLoading  = false;

        // Reset insights
        _insightTimer?.Stop();
        insights     = [];
        insightIndex = 0;

        StateHasChanged();

        try
        {
            settings = SettingsSvc.Load();

            var solarTask  = SolarService.GetCurrentAsync();
            var alertsTask = SolarService.GetAlertsAsync();
            await Task.WhenAll(solarTask, alertsTask);

            solar  = solarTask.Result;
            alerts = alertsTask.Result;

            if (settings.IsConfigured)
            {
                var (lat, lon) = SettingsService.MaidenheadToLatLon(settings.GridSquare);

                // Band conditions + insights load in parallel
                var insightsTask = LoadInsightsAsync(settings.Callsign, settings.GridSquare);

                bands = await HfService.GetBandConditionsAsync(lat, lon);
                _ = insightsTask;  // insights self-update via AddInsight → StateHasChanged

                // Destinations
                if (settings.TravelDestinations.Count > 0)
                {
                    destLoading = true;
                    StateHasChanged();
                    try
                    {
                        destinations = await TravelSvc.ResolveAllAsync(
                            settings.TravelDestinations, lat, lon, settings.Callsign);
                    }
                    catch { /* non-fatal */ }
                    finally { destLoading = false; }
                }

                // Satellites
                if (settings.SatellitesEnabled)
                {
                    try
                    {
                        passes = await SatService.GetPassesAsync(
                            settings.SatelliteWatchlist, lat, lon,
                            altKm: 0, minElevDeg: settings.MinSatElevation, hoursAhead: 24);
                    }
                    catch
                    {
                        errorMessage = "Satellite pass data unavailable.";
                    }
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Unable to fetch solar data: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    // ── Insight builders ──────────────────────────────────────────

    private async Task LoadInsightsAsync(string callsign, string gridSquare)
    {
        try
        {
            // 1. Phrase — local file, appears first
            var phrase = await PhraseSvc.GetRandomPhraseAsync();
            AddInsight(new GreetingInsight { Text = phrase.Text });

            // 2. Solar / band conditions summary
            // bands is set synchronously right after this task starts, before any await completes
            var excellent = bands.Where(b => b.Rating == BandRating.Excellent).Select(b => b.Band).ToList();
            var good      = bands.Where(b => b.Rating == BandRating.Good).Select(b => b.Band).ToList();
            var poor      = bands.Where(b => b.Rating is BandRating.Poor or BandRating.Closed).Select(b => b.Band).ToList();
            var bestList  = excellent.Any() ? excellent : good;
            var bestLabel = excellent.Any() ? "excellent" : "good";
            var solarParts = new List<string>();
            if (bestList.Any())
                solarParts.Add($"{string.Join(" ", bestList)} {bestLabel}");
            if (poor.Any())
                solarParts.Add($"{string.Join(" ", poor)} poor");
            if (solarParts.Any())
                AddInsight(new GreetingInsight
                {
                    Icon    = "📻 ",
                    Text    = string.Join(" · ", solarParts),
                    SubText = solar is not null ? $"SFI {solar.SolarFluxIndex} · Kp {solar.KIndex}" : ""
                });

            // 3. Last spotted + farthest spot — single fetch (PSKReporter JSONP caps large windows)
            var spots    = await PskSvc.GetRecentSpotsAsync(callsign, hoursBack: 24, JS);
            var latest   = spots.Count > 0 ? spots.MaxBy(s => s.Timestamp) : null;
            var farthest = PskSvc.GetFarthestSpotAsync(callsign, gridSquare, spots);

            if (latest is not null)
                AddInsight(new GreetingInsight
                {
                    Icon    = "📡 ",
                    Text    = $"Last spotted {latest.TimeAgo}",
                    SubText = string.IsNullOrEmpty(latest.ReceiverCallsign)
                        ? ""
                        : $"via {latest.ReceiverCallsign} · {latest.Band} {latest.Mode}"
                });
            else
                AddInsight(new GreetingInsight
                {
                    Icon    = "📡 ",
                    Text    = string.IsNullOrEmpty(PskSvc.LastError) ? "No recent spots — get on the air!" : "PSK Reporter unavailable",
                    SubText = string.IsNullOrEmpty(PskSvc.LastError) ? "" : "Spot data will appear when the service recovers"
                });

            if (farthest is not null && farthest.DistanceKm > 0)
                AddInsight(new GreetingInsight
                {
                    Icon    = "🌍 ",
                    Text    = $"Farthest spot: {farthest.DistanceDisplay}",
                    SubText = $"via {farthest.ReceiverCallsign} · {farthest.Band} {farthest.Mode} (24h)"
                });
        }
        catch { /* insights are non-critical */ }
    }

    private void AddInsight(GreetingInsight insight)
    {
        insights.Add(insight);
        if (insights.Count == 2) StartInsightTimer();
        InvokeAsync(StateHasChanged);
    }

    private void StartInsightTimer()
    {
        _insightTimer?.Dispose();
        _insightTimer = new System.Timers.Timer(5000) { AutoReset = true };
        _insightTimer.Elapsed += (_, _) =>
        {
            insightIndex = (insightIndex + 1) % Math.Max(1, insights.Count);
            InvokeAsync(StateHasChanged);
        };
        _insightTimer.Start();
    }

    public void Dispose() => _insightTimer?.Dispose();

    private static double HaversineKm(double lat1, double lon1, double lat2, double lon2)
    {
        const double R = 6371;
        double dLat = (lat2 - lat1) * Math.PI / 180;
        double dLon = (lon2 - lon1) * Math.PI / 180;
        double a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2)
                 + Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180)
                 * Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        return R * 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
    }
}
