@page "/settings"
@using GRRadio.Models
@using GRRadio.Services
@using System.Text.RegularExpressions
@using InTheHand.Net.Sockets
@inject SettingsService SettingsSvc
@inject SatelliteService SatSvc
@inject NavigationManager Nav
@inject BluetoothKissService BtSvc
@inject UIStateService UiState

<div class="page-header">
    <h1>Settings</h1>
</div>

<div class="settings-form">

    <!-- Station Identity -->
    <div class="settings-section">
        <h3 class="settings-section-title">Station</h3>

        <div class="form-group">
            <label class="form-label">Callsign</label>
            <input class="form-input" type="text"
                   placeholder="K5GRR"
                   @bind="callsign"
                   maxlength="12" />
        </div>

        <div class="form-group">
            <label class="form-label">Maidenhead Grid Square</label>
            <input class="form-input" type="text"
                   placeholder="EL29gp"
                   @bind="gridSquare"
                   maxlength="6" />
            <span class="form-hint">4 or 6 characters, e.g. EL29 or EL29gp</span>
        </div>

        <button class="btn-secondary" @onclick="UseDeviceLocation">
            📍 Use My Location
        </button>

        @if (!string.IsNullOrEmpty(locationMessage))
        {
            <div class="form-hint">@locationMessage</div>
        }
    </div>

    <!-- Satellite Settings -->
    <div class="settings-section">
        <h3 class="settings-section-title">Satellites</h3>

        <div class="form-group toggle-group">
            <label class="form-label">Satellites Enabled</label>
            <input type="checkbox" class="form-toggle" checked="@satellitesEnabled" @onchange="OnSatellitesEnabledChanged" />
        </div>
        <span class="form-hint">Shows upcoming passes on the Daily tab.</span>

        @if (satellitesEnabled)
        {

        <div class="form-group">
            <label class="form-label">Minimum Pass Elevation</label>
            <div class="slider-row">
                <input type="range" min="5" max="60" step="5"
                       @bind="minElevation" class="form-slider" />
                <span class="slider-value">@minElevation°</span>
            </div>
            <span class="form-hint">Passes below this angle are hidden by default</span>
        </div>

        <div class="form-group">
            <label class="form-label">Pass Alert</label>
            <div class="slider-row">
                <input type="range" min="1" max="15" step="1"
                       @bind="satPassAlertMinutes" class="form-slider" />
                <span class="slider-value">@satPassAlertMinutes min before AOS</span>
            </div>
            <span class="form-hint">How early to notify you before a tracked pass begins</span>
        </div>

        <div class="form-group">
            <div class="collapsible-header" style="margin-bottom:0;" @onclick='() => UiState.Toggle("settings.satcatalog", false)'>
                <label class="form-label" style="pointer-events:none;">
                    Satellites to Track
                    @if (watchedNoradIds.Count > 0)
                    {
                        <span class="sat-selected-count">@watchedNoradIds.Count selected</span>
                    }
                </label>
                <span class="collapse-chevron">@(UiState.Get("settings.satcatalog", false) ? "▲" : "▼")</span>
            </div>

            @if (UiState.Get("settings.satcatalog", false))
            {
                <div class="sat-catalog-container">
                    <input class="form-input sat-catalog-search" type="text"
                           placeholder="Filter satellites…"
                           @bind="satFilter"
                           @bind:event="oninput" />

                    @if (satCatalogLoading)
                    {
                        <div class="form-hint" style="padding:8px;">Loading satellite list…</div>
                    }
                    else
                    {
                        var filtered = string.IsNullOrWhiteSpace(satFilter)
                            ? satCatalog
                            : satCatalog.Where(s =>
                                s.Name.Contains(satFilter, StringComparison.OrdinalIgnoreCase) ||
                                s.Freq.Contains(satFilter, StringComparison.OrdinalIgnoreCase)).ToList();

                        <div class="sat-catalog-scroll">
                            @foreach (var group in filtered.GroupBy(s => s.Mode))
                            {
                                <div class="sat-group-label">@group.Key</div>
                                @foreach (var sat in group)
                                {
                                    <label class="sat-catalog-item">
                                        <input type="checkbox"
                                               checked="@IsSatWatched(sat.NoradId)"
                                               @onchange="e => ToggleSat(sat.NoradId, (bool)e.Value!)" />
                                        <div class="sat-catalog-info">
                                            <span class="sat-catalog-name">@sat.Name</span>
                                            @if (!string.IsNullOrEmpty(sat.Freq))
                                            {
                                                <span class="sat-catalog-notes">@sat.Freq</span>
                                            }
                                        </div>
                                    </label>
                                }
                            }
                        </div>
                    }
                </div>
            }

            @{
                var customIds = watchedNoradIds
                    .Where(id => !satCatalog.Any(s => s.NoradId == id))
                    .ToList();
            }
            @if (customIds.Count > 0)
            {
                <div class="sat-group-label">Unlisted</div>
                @foreach (var id in customIds)
                {
                    <div class="watchlist-item">
                        <span>NORAD @id</span>
                        <button class="watchlist-remove" @onclick="() => RemoveSat(id)">✕</button>
                    </div>
                }
            }

            <div class="watchlist-add" style="margin-top: 8px;">
                <input class="form-input" type="text"
                       placeholder="Add unlisted satellite…"
                       @bind="newSatName"
                       @onkeyup="OnSatKeyUp" />
                <button class="btn-secondary" @onclick="AddSat">Add</button>
            </div>
        </div>

        <button class="btn-ghost" style="margin-top: 4px;" @onclick='() => Nav.NavigateTo("/satellites")'>
            View all passes →
        </button>
        }
    </div>

    <!-- News Settings -->
    <div class="settings-section">
        <h3 class="settings-section-title">News</h3>
        <div class="form-group">
            <label class="form-label">Subreddits</label>
            <div class="watchlist">
                @foreach (var sub in newsSubreddits)
                {
                    <div class="watchlist-item">
                        <span>r/@sub</span>
                        <button class="watchlist-remove" @onclick="() => RemoveSub(sub)">✕</button>
                    </div>
                }
            </div>
            <div class="watchlist-add">
                <input class="form-input" type="text"
                       placeholder="subreddit name (no r/)"
                       @bind="newSubName"
                       @onkeyup="OnSubKeyUp" />
                <button class="btn-secondary" @onclick="AddSub">Add</button>
            </div>
        </div>
    </div>


    <!-- App Settings -->
    <div class="settings-section">
        <h3 class="settings-section-title">App</h3>


        @*
        <div class="form-group toggle-group">
            <label class="form-label">Dark Mode</label>
            <input type="checkbox" class="form-toggle" @bind="darkMode" />
        </div>
        *@

        @*
        <div class="form-group toggle-group">
            <label class="form-label">Daily Report</label>
            <input type="checkbox" class="form-toggle" @bind="dailyReportEnabled" />
        </div>
        <span class="form-hint">Morning briefing — band conditions, passes, and a motivational phrase.</span>
        *@

        <button class="btn-ghost" style="margin-top: 12px;" @onclick='() => Nav.NavigateTo("/phrase-admin")'>
            Manage Phrases →
        </button>
    </div>

    <!-- Travel / Destinations -->
    <div class="settings-section">
        <h3 class="settings-section-title">Travel</h3>
        <span class="form-hint" style="display:block; margin-bottom: 12px;">
            Add POTA references (K-1234) or location names. Destination cards appear on the Daily tab.
        </span>

        <div class="watchlist">
            @foreach (var dest in travelDestinations)
            {
                <div class="watchlist-item">
                    <span class="dest-badge @(dest.IsPota ? "dest-pota" : "dest-place")">
                        @(dest.IsPota ? "POTA" : "Place")
                    </span>
                    <span>@dest.Input</span>
                    <button class="watchlist-remove" @onclick="() => RemoveDest(dest)">✕</button>
                </div>
            }
        </div>

        <div class="watchlist-add">
            <input class="form-input" type="text"
                   placeholder="K-1234 or place name…"
                   @bind="newDestInput"
                   @onkeyup="OnDestKeyUp" />
            <button class="btn-secondary" @onclick="AddDest">Add</button>
        </div>
    </div>

    <!-- APRS Chat -->
    <div class="settings-section">
        <h3 class="settings-section-title">APRS Chat</h3>

        <div class="form-group toggle-group">
            <label class="form-label">I have a BTECH UV Pro (or similar KISS TNC)</label>
            <input type="checkbox" class="form-toggle" @bind="aprsEnabled" />
        </div>

        @if (aprsEnabled)
        {
        <span class="form-hint" style="display:block; margin-bottom: 12px;">
            Connect via Bluetooth SPP to send and receive APRS messages.
        </span>

        <div class="form-group">
            <label class="form-label">SSID</label>
            <div class="slider-row">
                <input type="range" min="0" max="15" step="1"
                       @bind="aprsSSID" class="form-slider" />
                <span class="slider-value">-@aprsSSID</span>
            </div>
            <span class="form-hint">Your station suffix (e.g. @(string.IsNullOrWhiteSpace(callsign) ? "N0CALL" : callsign)-@aprsSSID)</span>
        </div>

        <div class="form-group">
            <label class="form-label">APRS Symbol</label>
            <div class="symbol-picker">
                @foreach (var sym in AprsSymbols.PickerSymbols)
                {
                    <button type="button"
                            class="symbol-btn @(aprsSymbol == sym.Code ? "symbol-btn-selected" : "")"
                            title="@sym.Name (@sym.Code)"
                            @onclick="() => aprsSymbol = sym.Code">
                        @sym.Emoji
                    </button>
                }
            </div>
            <span class="form-hint">@AprsSymbols.GetEmoji(aprsSymbol) @AprsSymbols.GetName(aprsSymbol) (@aprsSymbol)</span>
        </div>

        <div class="form-group">
            <label class="form-label">Beacon Comment</label>
            <input class="form-input" type="text"
                   placeholder="Auto (callsign + grid)"
                   @bind="aprsComment"
                   maxlength="43" />
        </div>

        <div class="form-group toggle-group">
            <label class="form-label">Auto-Beacon</label>
            <input type="checkbox" class="form-toggle" @bind="beaconEnabled" />
        </div>

        @if (beaconEnabled)
        {
            <div class="form-group">
                <label class="form-label">Beacon Interval</label>
                <div class="slider-row">
                    <input type="range" min="60" max="1800" step="60"
                           @bind="beaconInterval" class="form-slider" />
                    <span class="slider-value">@(beaconInterval / 60)m</span>
                </div>
            </div>
        }

        <div class="form-group">
            <label class="form-label">Bluetooth TNC Device</label>
            @if (string.IsNullOrEmpty(btDeviceName))
            {
                <span class="form-hint">No device selected.</span>
            }
            else
            {
                <div class="watchlist-item" style="margin-bottom: 6px;">
                    <span>@btDeviceName</span>
                    <button class="watchlist-remove" @onclick="ClearBtDevice">✕</button>
                </div>
            }
            <button class="btn-secondary" @onclick="ScanBtDevicesAsync" disabled="@btScanning">
                @(btScanning ? "Scanning…" : "Scan for Devices")
            </button>
            @if (btDevices.Count > 0)
            {
                <div class="watchlist" style="margin-top: 8px;">
                    @foreach (var d in btDevices)
                    {
                        <div class="watchlist-item" style="cursor:pointer;" @onclick="() => SelectBtDevice(d.DeviceName, d.DeviceAddress.ToString())">
                            <span>@d.DeviceName</span>
                            <span class="form-hint">@d.DeviceAddress</span>
                        </div>
                    }
                </div>
            }
            @if (!string.IsNullOrEmpty(btScanMessage))
            {
                <span class="form-hint">@btScanMessage</span>
            }
        </div>
        } @* end aprsEnabled *@
    </div>

    <!-- Save -->
    <div class="settings-actions">
        <button class="btn-primary" @onclick="Save">Save Settings</button>
    </div>

    <!-- About -->
    <div style="text-align:center; padding: 16px 0 8px;">
        <button class="btn-ghost about-link" @onclick="() => showAbout = true">About GRRadio</button>
    </div>

</div>

@if (showAbout)
{
    <div class="about-overlay" @onclick="() => showAbout = false">
        <div class="about-modal" @onclick:stopPropagation>
            <div class="about-modal-header">
                <span>About GRRadio</span>
                <button class="modal-close" @onclick="() => showAbout = false">✕</button>
            </div>
            <div class="about-modal-body">
                <p class="about-tagline">A mobile ham radio companion built for the field and the shack.</p>

                <h3 class="about-section-title">Data Sources</h3>

                <div class="about-source">
                    <span class="about-source-name">GRRadio Weather API</span>
                    <span class="about-source-desc">HF band conditions — grrwx.atomicbliss.dev</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">NOAA Space Weather</span>
                    <span class="about-source-desc">Solar indices, Kp, geomagnetic data, and alerts — swpc.noaa.gov</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">HamQSL</span>
                    <span class="about-source-desc">Solar condition data (fallback) — hamqsl.com</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">PSK Reporter</span>
                    <span class="about-source-desc">Real-time signal reception reports — pskreporter.info</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">AMSAT</span>
                    <span class="about-source-desc">Satellite TLE data and operational status — amsat.org</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">DX World</span>
                    <span class="about-source-desc">DX expedition news — dx-world.net</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">Reddit</span>
                    <span class="about-source-desc">Ham radio community news — reddit.com</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">Callook</span>
                    <span class="about-source-desc">FCC callsign lookup — callook.info</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">QRZ</span>
                    <span class="about-source-desc">Logbook API and ham classifieds — qrz.com</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">QTH Swap</span>
                    <span class="about-source-desc">Ham radio classifieds — swap.qth.com</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">Parks on the Air</span>
                    <span class="about-source-desc">POTA park and activator data — api.pota.app</span>
                </div>
                <div class="about-source">
                    <span class="about-source-name">Wikipedia</span>
                    <span class="about-source-desc">Travel destination summaries — wikipedia.org</span>
                </div>

                <p class="about-footer">Made with ♥ by K5GRR</p>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(saveMessage))
{
    <div class="save-toast @(saveSuccess ? "toast-success" : "toast-error")">
        @saveMessage
    </div>
}

@code {
    // ── Satellite catalog ─────────────────────────────────────────
    private record SatEntry(string Name, string Mode, string Freq, int NoradId);

    // Known frequency/mode info keyed by NORAD catalog number
    private static readonly Dictionary<int, (string Mode, string Freq)> KnownSats = new()
    {
        [25544] = ("FM Voice",    "145.800 ↓ · APRS 145.825"),   // ISS (ZARYA)
        [27607] = ("FM Voice",    "145.850 ↓ · 67.0 Hz PL up"),  // SO-50
        [43017] = ("FM Voice",    "145.960 ↓ · FOX-1B"),         // AO-91
        [43678] = ("FM Voice",    "145.900 ↓ · Diwata-2"),       // PO-101
        [50986] = ("FM Voice",    "435.600 ↓"),                   // TEVEL-1
        [50987] = ("FM Voice",    "435.600 ↓"),                   // TEVEL-2
        [40908] = ("FM Voice",    "437.200 ↓"),                   // LILACSAT-2
        [40931] = ("FM Voice",    "435.880 ↓"),                   // IO-86
        [22825] = ("FM Voice",    "436.795 ↓"),                   // AO-27
        [49016] = ("FM Voice",    "436.100 ↓"),                   // HO-113 (XW-3)
        [44909] = ("Linear / SSB","145.935 ↓ · 435.640 ↑"),      // RS-44
        [24278] = ("Linear / SSB","145.900 ↓ · 435.800 ↑"),      // FO-29
        [7530]  = ("Linear / SSB","145.975 ↓ · Mode B"),          // AO-07
        [39444] = ("Linear / SSB","145.950 ↓ · 435.130 ↑"),      // AO-73
        [43803] = ("Linear / SSB","145.855 ↓ · 435.100 ↑"),      // JO-97
        [40903] = ("Linear / SSB","145.670 ↓"),                   // XW-2A
        [42761] = ("Linear / SSB","435.210 ↓"),                   // CAS-4A
        [42759] = ("Linear / SSB","435.280 ↓"),                   // CAS-4B
        [42788] = ("Linear / SSB","436.675 ↓"),                   // LO-74
        [46852] = ("Linear / SSB","145.915 ↓ · 435.315 ↑"),      // TO-108 (CAS-6)
        [43700] = ("Linear / SSB","10489.5 MHz ↓ · 2400 MHz ↑"), // QO-100
        [28650] = ("CW / Beacon", "435.352 ↓"),                   // RS-22
        [43743] = ("CW / Beacon", "145.880 ↓"),                   // AO-95
    };

    private List<SatEntry> satCatalog = [];
    private bool satCatalogLoading = false;
    private string satFilter = "";

    private bool IsSatWatched(int noradId) => watchedNoradIds.Contains(noradId);

    private void ToggleSat(int noradId, bool add)
    {
        if (add) watchedNoradIds.Add(noradId);
        else     watchedNoradIds.Remove(noradId);
    }

    // ── Form state ────────────────────────────────────────────────
    private string callsign = "";
    private string gridSquare = "";
    private int minElevation        = 10;
    private int satPassAlertMinutes = 5;
    private HashSet<int> watchedNoradIds = [];
    private List<string> newsSubreddits = [];
    private bool darkMode = true;
    private bool dailyReportEnabled = false;
    private bool satellitesEnabled = false;
    private string newSatName = "";
    private string newSubName = "";
    private string newDestInput = "";
    private List<TravelDestination> travelDestinations = [];
    private string locationMessage = "";
    private string saveMessage = "";
    private bool saveSuccess  = false;
    private bool showAbout    = false;

    // APRS Chat
    private bool   aprsEnabled     = false;
    private int    aprsSSID        = 9;
    private string aprsSymbol      = "/-";
    private string aprsComment     = "";
    private bool   beaconEnabled   = false;
    private int    beaconInterval  = 600;
    private string btDeviceName    = "";
    private string btDeviceAddress = "";
    private bool   btScanning      = false;
    private string btScanMessage   = "";
    private List<InTheHand.Net.Sockets.BluetoothDeviceInfo> btDevices = [];

    protected override async Task OnInitializedAsync()
    {
        var s = SettingsSvc.Load();
        callsign           = s.Callsign;
        gridSquare         = s.GridSquare;
        minElevation        = s.MinSatElevation;
        satPassAlertMinutes = s.SatPassAlertMinutes;
        watchedNoradIds    = [.. s.WatchedNoradIds];
        newsSubreddits     = [.. s.NewsSubreddits];
        travelDestinations = [.. s.TravelDestinations];
        darkMode           = s.DarkMode;
        dailyReportEnabled = s.DailyReportEnabled;
        satellitesEnabled  = s.SatellitesEnabled;
        aprsEnabled        = s.AprsEnabled;
        aprsSSID           = s.AprsSSID;
        aprsSymbol         = s.AprsSymbol;
        aprsComment        = s.AprsComment;
        beaconEnabled      = s.BeaconEnabled;
        beaconInterval     = s.BeaconInterval;
        btDeviceName       = s.BluetoothDeviceName;
        btDeviceAddress    = s.BluetoothDeviceAddress;

        await LoadSatCatalogAsync();
    }

    private async Task LoadSatCatalogAsync()
    {
        satCatalogLoading = true;
        try
        {
            var sats = await SatSvc.GetSatellitesAsync();
            satCatalog = sats.Select(s =>
            {
                if (KnownSats.TryGetValue(s.NoradId, out var info))
                    return new SatEntry(s.Name, info.Mode, info.Freq, s.NoradId);
                return new SatEntry(s.Name, "Other", "", s.NoradId);
            })
            .OrderBy(s => s.Mode == "Other" ? 1 : 0)
            .ThenBy(s => s.Mode)
            .ThenBy(s => s.Name)
            .ToList();
        }
        catch
        {
            satCatalog = KnownSats
                .Select(kv => new SatEntry($"NORAD {kv.Key}", kv.Value.Mode, kv.Value.Freq, kv.Key))
                .OrderBy(s => s.Mode).ThenBy(s => s.Name).ToList();
        }
        finally
        {
            satCatalogLoading = false;
        }
    }

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(callsign))
        {
            saveMessage = "Callsign is required.";
            saveSuccess = false;
            return;
        }

        if (gridSquare.Length is not (4 or 6))
        {
            saveMessage = "Grid square must be 4 or 6 characters.";
            saveSuccess = false;
            return;
        }

        var (lat, lon) = SettingsService.MaidenheadToLatLon(gridSquare);

        SettingsSvc.Save(new UserSettings
        {
            Callsign              = callsign.ToUpperInvariant().Trim(),
            GridSquare            = gridSquare.ToUpperInvariant().Trim(),
            Latitude              = lat,
            Longitude             = lon,
            MinSatElevation       = minElevation,
            SatPassAlertMinutes   = satPassAlertMinutes,
            WatchedNoradIds       = watchedNoradIds,
            NewsSubreddits        = newsSubreddits,
            TravelDestinations    = travelDestinations,
            DarkMode              = darkMode,
            DailyReportEnabled    = dailyReportEnabled,
            SatellitesEnabled     = satellitesEnabled,
            AprsEnabled           = aprsEnabled,
            AprsSSID              = aprsSSID,
            AprsSymbol            = aprsSymbol.Trim(),
            AprsComment           = aprsComment.Trim(),
            BeaconEnabled         = beaconEnabled,
            BeaconInterval        = beaconInterval,
            BluetoothDeviceName   = btDeviceName,
            BluetoothDeviceAddress = btDeviceAddress
        });

        saveMessage = "Settings saved!";
        saveSuccess = true;
        _ = Task.Delay(2500).ContinueWith(_ => { saveMessage = ""; InvokeAsync(StateHasChanged); });
    }

    private async Task UseDeviceLocation()
    {
        locationMessage = "Detecting location…";
        try
        {
            var status = await Permissions.RequestAsync<Permissions.LocationWhenInUse>();
            if (status != PermissionStatus.Granted)
            {
                locationMessage = "Location permission denied. Enable it in Settings.";
                return;
            }

            var location = await Geolocation.Default.GetLocationAsync(new GeolocationRequest
            {
                DesiredAccuracy = GeolocationAccuracy.Medium,
                Timeout = TimeSpan.FromSeconds(10)
            });

            if (location is not null)
            {
                gridSquare = SettingsService.LatLonToMaidenhead(location.Latitude, location.Longitude);
                locationMessage = $"Grid: {gridSquare} ({location.Latitude:F4}°, {location.Longitude:F4}°)";
            }
            else
            {
                locationMessage = "Could not get location.";
            }
        }
        catch (Exception ex)
        {
            locationMessage = $"Location error: {ex.Message}";
        }
    }

    // ISS, SO-50, AO-91, IO-86, RS-44
    private static readonly int[] DefaultNoradIds = [25544, 27607, 43017, 40931, 44909];

    private void OnSatellitesEnabledChanged(ChangeEventArgs e)
    {
        satellitesEnabled = (bool)(e.Value ?? false);
        if (satellitesEnabled && watchedNoradIds.Count == 0)
            foreach (var id in DefaultNoradIds) watchedNoradIds.Add(id);
    }

    private void AddSat()
    {
        var query = newSatName.Trim();
        if (string.IsNullOrEmpty(query)) return;

        var match = satCatalog.FirstOrDefault(s =>
            s.Name.Equals(query, StringComparison.OrdinalIgnoreCase) ||
            s.Name.Contains(query, StringComparison.OrdinalIgnoreCase));

        if (match is null) return;

        watchedNoradIds.Add(match.NoradId);
        newSatName = "";
    }

    private void RemoveSat(int noradId) => watchedNoradIds.Remove(noradId);

    private void OnSatKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddSat();
    }

    private void AddSub()
    {
        var name = newSubName.Trim().ToLowerInvariant().TrimStart('/').Replace("r/", "");
        if (!string.IsNullOrEmpty(name) && !newsSubreddits.Contains(name))
        {
            newsSubreddits.Add(name);
            newSubName = "";
        }
    }

    private void RemoveSub(string sub) => newsSubreddits.Remove(sub);

    private void OnSubKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddSub();
    }

    private void AddDest()
    {
        var input = newDestInput.Trim();
        if (!string.IsNullOrEmpty(input) && !travelDestinations.Any(d => d.Input.Equals(input, StringComparison.OrdinalIgnoreCase)))
        {
            travelDestinations.Add(new TravelDestination { Input = input });
            newDestInput = "";
        }
    }

    private void RemoveDest(TravelDestination dest) => travelDestinations.Remove(dest);

    private void OnDestKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddDest();
    }

    private async Task ScanBtDevicesAsync()
    {
        btScanning   = true;
        btScanMessage = "";
        btDevices    = [];
        StateHasChanged();
        var devices = await BtSvc.GetPairedDevicesAsync();
        btDevices = devices.ToList();
        btScanMessage = btDevices.Count == 0 ? "No paired devices found." : "";
        btScanning = false;
    }

    private void SelectBtDevice(string name, string address)
    {
        btDeviceName    = name;
        btDeviceAddress = address;
        btDevices       = [];
        btScanMessage   = "";
    }

    private void ClearBtDevice()
    {
        btDeviceName    = "";
        btDeviceAddress = "";
    }

}
